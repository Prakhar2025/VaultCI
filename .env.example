# ── GitHub ──────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=ghp_your_personal_access_token

# ── Groq (free at console.groq.com) ────────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_PASSWORD=vaultci_secret

# ── Qdrant (local Docker - no key needed) ───────────────
# QDRANT_HOST and QDRANT_PORT are set in docker-compose.yml
# For local dev outside Docker: QDRANT_HOST=localhost
